{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cortex Debug (OpenOCD)",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/blink.elf",
            "servertype": "openocd",
            "configFiles": [
                "board/stm32f4discovery.cfg"
            ],
            "device": "STM32F429ZI",
            "runToEntryPoint": "main",
            "svdFile": "",
            "showDevDebugOutput": "none"
        }
    ]
}
